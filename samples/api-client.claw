print("Base URL: " + api.baseUrl);

// Set authentication
api.setAuth("my-secret-token");
print("Auth: Bearer my-secret-token");

// Create resource APIs
var users = createUsersApi(api);
var posts = createPostsApi(api);

print("\n--- Available APIs ---");
print("- users: list, get, create, update, patch, remove");
print("- posts: list, get, create, update, patch, remove, getComments");

// Demo: Building requests (without actually calling)
print("\n--- Request Examples ---");

print("\n1. List all users:");
