// Usage pattern
print("\n--- Usage Pattern ---");
print(`
var client = createClient("https://api.example.com");
var usersApi = createUsersApi(client);

// List users
var result = usersApi.list({ active: true });
if (result.ok) {
  print("Users: " + len(result.data));
} else {
  print("Error: " + result.error);
}

// Get single user
var user = usersApi.get(1);
if (user.ok) {
  print("User: " + user.data.name);
}

// Create user
var newUser = usersApi.create({
  name: "John Doe",
  email: "john@example.com"
});
`);

// Pagination example
print("\n--- Pagination Example ---");
print(`
var page = 1;
var limit = 10;
var allPosts = [];

while (true) {
  var result = posts.list({ _page: page, _limit: limit });
  if (!result.ok || len(result.data) == 0) break;
  
  allPosts = allPosts + result.data;
  
  if (len(result.data) < limit) break;
  page = page + 1;
}

print("Total posts: " + len(allPosts));
`);

print("\n=== Demo Complete ===");
