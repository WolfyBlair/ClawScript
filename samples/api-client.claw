// REST API Client Library
// Demonstrates: HTTP requests, CRUD operations, pagination, error handling

// Note: Requires addons: ["http"] and allowNetwork: true

// API Client configuration
var BASE_URL = "https://jsonplaceholder.typicode.com";
var DEFAULT_TIMEOUT = 10000;

// Create HTTP client
function createClient(baseUrl) {
  return {
    baseUrl: baseUrl || BASE_URL,
    defaultHeaders: {
      "Content-Type": "application/json"
    },
    authToken: null,
    
    setAuth: function(token) {
      this.authToken = token;
    },
    
    setHeader: function(key, value) {
      this.defaultHeaders[key] = value;
    },
    
    getUrl: function(endpoint) {
      if (String.startsWith(endpoint, "http")) {
        return endpoint;
      }
      var url = this.baseUrl;
      if (!String.endsWith(url, "/") && !String.startsWith(endpoint, "/")) {
        url = url + "/";
      }
      return url + endpoint;
    },
    
    getHeaders: function(extraHeaders) {
      var headers = {};
      for (var key in this.defaultHeaders) {
        headers[key] = this.defaultHeaders[key];
      }
      if (this.authToken) {
        headers["Authorization"] = "Bearer " + this.authToken;
      }
      if (extraHeaders) {
        for (var key in extraHeaders) {
          headers[key] = extraHeaders[key];
        }
      }
      return headers;
    }
  };
}

// GET request
function get(client, endpoint, params, options) {
  var url = client.getUrl(endpoint);
  
  // Add query params
  if (params) {
    var query = [];
    for (var key in params) {
      query = Array.push(query, key + "=" + encodeURIComponent(params[key]));
    }
    if (len(query) > 0) {
      url = url + "?" + Array.join(query, "&");
    }
  }
  
  var requestOptions = {
    headers: client.getHeaders(options?.headers),
    timeout: options?.timeout || DEFAULT_TIMEOUT
  };
  
  return Http.get(url, requestOptions);
}

// POST request
function post(client, endpoint, data, options) {
  var url = client.getUrl(endpoint);
  var body = typeof data == "string" ? data : JSON.stringify(data);
  
  var requestOptions = {
    headers: client.getHeaders(options?.headers),
    timeout: options?.timeout || DEFAULT_TIMEOUT
  };
  
  return Http.post(url, body, requestOptions);
}

// PUT request
function put(client, endpoint, data, options) {
  var url = client.getUrl(endpoint);
  var body = typeof data == "string" ? data : JSON.stringify(data);
  
  var requestOptions = {
    headers: client.getHeaders(options?.headers),
    timeout: options?.timeout || DEFAULT_TIMEOUT
  };
  
  return Http.put(url, body, requestOptions);
}

// PATCH request
function patch(client, endpoint, data, options) {
  var url = client.getUrl(endpoint);
  var body = typeof data == "string" ? data : JSON.stringify(data);
  
  var requestOptions = {
    headers: client.getHeaders(options?.headers),
    timeout: options?.timeout || DEFAULT_TIMEOUT
  };
  
  return Http.patch(url, body, requestOptions);
}

// DELETE request
function del(client, endpoint, options) {
  var url = client.getUrl(endpoint);
  
  var requestOptions = {
    headers: client.getHeaders(options?.headers),
    timeout: options?.timeout || DEFAULT_TIMEOUT
  };
  
  return Http.delete(url, requestOptions);
}

// Encode URI component
function encodeURIComponent(str) {
  return String.replace(String.replace(String.replace(String.replace(String.replace(String.replace(
    String.replace(str, "%", "%25"),
    "!", "%21"),
    "#", "%23"),
    "$", "%24"),
    "&", "%26"),
    "'", "%27"),
    "(", "%28"),
    ")", "%29"),
    "*", "%2A"),
    "+", "%2B"),
    ",", "%2C"),
    "/", "%2F"),
    ":", "%3A"),
    ";", "%3B"),
    "=", "%3D"),
    "?", "%3F"),
    "@", "%40"),
    "[", "%5B"),
    "]", "%5D");
}

// ========== DATA MAPPING ==========

// Map JSON to object
function mapToObject(json) {
  if (typeof json == "string") {
    try {
      return JSON.parse(json);
    } catch {
      return null;
    }
  }
  return json;
}

// Extract data from response
function extractData(response) {
  if (!response) {
    return { error: "No response" };
  }
  if (response.error) {
    return { error: response.error };
  }
  if (!response.ok) {
    return { error: "HTTP " + response.status + ": " + response.statusText };
  }
  return { 
    ok: true, 
    data: response.body, 
    status: response.status,
    headers: response.headers 
  };
}

// ========== CRUD OPERATIONS ==========

// Generic CRUD for any resource
function createCrud(client, resource) {
  return {
    resource: resource,
    
    // List all with optional filtering and pagination
    list: function(params, options) {
      var result = get(client, this.resource, params, options);
      return extractData(result);
    },
    
    // Get single by ID
    get: function(id, options) {
      var result = get(client, this.resource + "/" + id, null, options);
      return extractData(result);
    },
    
    // Create new
    create: function(data, options) {
      var result = post(client, this.resource, data, options);
      return extractData(result);
    },
    
    // Update (full)
    update: function(id, data, options) {
      var result = put(client, this.resource + "/" + id, data, options);
      return extractData(result);
    },
    
    // Update (partial)
    patch: function(id, data, options) {
      var result = patch(client, this.resource + "/" + id, data, options);
      return extractData(result);
    },
    
    // Delete
    remove: function(id, options) {
      var result = del(client, this.resource + "/" + id, options);
      return extractData(result);
    },
    
    // Pagination helper
    paginate: function(page, limit, params, options) {
      var p = params || {};
      p._page = page;
      p._limit = limit;
      return this.list(p, options);
    }
  };
}

// ========== API EXAMPLES ==========

// Users API
function createUsersApi(client) {
  var crud = createCrud(client, "users");
  
  return {
    ...crud,
    
    // Get user's posts
    getPosts: function(userId, options) {
      var result = get(client, "posts", { userId: userId }, options);
      return extractData(result);
    },
    
    // Get user's albums
    getAlbums: function(userId, options) {
      var result = get(client, "albums", { userId: userId }, options);
      return extractData(result);
    },
    
    // Get user's todos
    getTodos: function(userId, options) {
      var result = get(client, "todos", { userId: userId }, options);
      return extractData(result);
    }
  };
}

// Posts API
function createPostsApi(client) {
  var crud = createCrud(client, "posts");
  
  return {
    ...crud,
    
    // Get comments for post
    getComments: function(postId, options) {
      var result = get(client, "posts/" + postId + "/comments", null, options);
      return extractData(result);
    }
  };
}

// ========== DEMO ==========

// Note: This demo shows the library structure
// Run with actual HTTP addon enabled for live API calls

print("=== REST API Client Library Demo ===\n");

// Create API client
