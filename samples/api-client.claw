print('   { "email": "newemail@example.com" }');

print("\n7. Delete user:");
print("   DELETE /users/1");

print("\n8. Nested resources:");
print("   GET /users/1/posts");
print("   GET /posts/1/comments");

print("\n9. Pagination:");
print("   GET /posts?_page=1&_limit=10");

print("\n10. Search:");
print("   GET /posts?title=hello");

// Simulate API response structure
